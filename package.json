{
  "name": "retouche",
  "private": true,
  "scripts": {
    "ci:version": "pnpm changeset version",
    "ci:publish": "pnpm --recursive build && pnpm --recursive publish --filter \"@retouche/*\" --filter \"retouche\" --filter \"vite-plugin-retouche\" --access public",
    "test": "pnpm run --recursive test --passWithNoTests",
    "build": "pnpm run --recursive build",
    "coverage": "pnpm run --recursive coverage",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@commitlint/cli": "^20.4.4",
    "@commitlint/config-conventional": "^20.4.4",
    "@microsoft/api-extractor": "^7.57.7",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "commitizen": "^4.3.1",
    "commitlint": "^20.4.4",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^10.0.3",
    "eslint-plugin-svelte": "^3.15.2",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "rollup": "^4.59.0",
    "typescript": "^5.9.3",
    "unplugin-dts": "1.0.0-beta.6",
    "vite": "^8.0.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.0"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  }
}
